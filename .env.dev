# Development Environment - Crypto Invoicing

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Supabase (DEV instance - create separate project)
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Google OAuth (DEV)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-dev-google-client-id
GOOGLE_CLIENT_SECRET=your-dev-google-client-secret

# Email (Resend - DEV)
RESEND_API_KEY=your-dev-resend-api-key
RESEND_FROM_EMAIL=dev@cryptoinvoicing.local

# Telegram Bot (DEV)
TELEGRAM_BOT_TOKEN=your-dev-telegram-token
TELEGRAM_CHAT_ID=your-dev-chat-id

# Sentry (DEV)
NEXT_PUBLIC_SENTRY_DSN=your-dev-sentry-dsn
SENTRY_AUTH_TOKEN=your-dev-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=crypto-invoicing-dev

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=your-dev-posthog-key

# Alchemy (Base Sepolia testnet for DEV)
ALCHEMY_API_KEY=your-dev-alchemy-key

# Sumsub (DEV sandbox)
SUMSUB_API_KEY=your-dev-sumsub-api-key
SUMSUB_SECRET_KEY=your-dev-sumsub-secret-key
