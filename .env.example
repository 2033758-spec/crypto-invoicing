 такой# Supabase (lead capture)
# Создать project на supabase.com → Settings → API → скопировать URL + keys.
# Прогнать миграцию: supabase/migrations/0001_init.sql через SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (error tracking — day 1 per decisions_log 2026-05-12)
# Создать project на sentry.io → Settings → Client Keys (DSN).
# Public DSN (одинаковый для client и server в Next.js).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional — нужны только для source-maps upload в production build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog analytics (events: page view / slider change / email submit / share)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Public site URL (used for share links)
NEXT_PUBLIC_SITE_URL=

# Resend (waitlist confirmation email)
RESEND_API_KEY=

# Telegram bot (ops notifications — founder concierge mode)
# ⚠️ NEVER commit real tokens to this file! Use only in .env.local
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_FOUNDER_CHAT_ID=
# ^ TODO: get from @userinfobot in Telegram, paste your numeric chat_id here
SUPABASE_AUTH_WEBHOOK_SECRET=
NEXT_PUBLIC_GSC_VERIFICATION=
