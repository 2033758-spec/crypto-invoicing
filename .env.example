# ============================================================================
# CRYPTO INVOICING — Environment Variables
#
# ⚠️ IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are PUBLIC (visible in browser).
# Other variables are SECRET (server-only). NEVER commit real secrets to git.
# Use .env.local for development, Vercel dashboard for production.
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# 🔴 SECRET (server-only, never expose to client/browser)
# ────────────────────────────────────────────────────────────────────────────

# Supabase service role (full DB access, bypass RLS)
# Get from: supabase.com → project → Settings → API → Service role secret
# ⚠️ NEVER expose in browser code or frontend
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key (email delivery)
# Get from: resend.com → API Keys → Create
# Used for: Magic-link signup emails
RESEND_API_KEY=

# Telegram bot token (ops notifications)
# Get from: @BotFather on Telegram
# ⚠️ NEVER commit real token! Use only in .env.local
TELEGRAM_BOT_TOKEN=
TELEGRAM_FOUNDER_CHAT_ID=

# Supabase webhook secret (auth-hook verification)
# Generate random secret: openssl rand -hex 32
SUPABASE_AUTH_WEBHOOK_SECRET=

# Sentry auth token (optional, only needed for source-map uploads)
# Get from: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ────────────────────────────────────────────────────────────────────────────
# 🟡 PUBLIC (visible in browser, safe to expose)
# ────────────────────────────────────────────────────────────────────────────

# Supabase URL + anon key (public, RLS-protected)
# Get from: supabase.com → project → Settings → API → Project URL & Anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry public DSN (error tracking)
# Get from: sentry.io → project → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog analytics (events tracking)
# Get from: posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Site URL (used for email links, share buttons)
NEXT_PUBLIC_SITE_URL=https://cryptoinvoicing.co

# Google Search Console verification (optional)
NEXT_PUBLIC_GSC_VERIFICATION=

# Telegram bot username (for display purposes)
TELEGRAM_BOT_USERNAME=

# ════════════════════════════════════════════════════════════════════════════
# Setup checklist:
# 1. Create Supabase project → copy URL + keys
# 2. Create Sentry project → copy DSN
# 3. Create PostHog account → copy API key
# 4. Create Telegram bot → copy token
# 5. Copy .env.example → .env.local and fill in all values
# 6. NEVER commit .env.local or .env to Git
# ════════════════════════════════════════════════════════════════════════════
