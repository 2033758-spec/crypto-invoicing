# ⚠️ LOCAL DEVELOPMENT ONLY
# Copy this to .env.local and fill in YOUR credentials
# .env.local is NEVER committed to Git (listed in .gitignore)

# Telegram bot (local dev only)
# Get real token from @BotFather
TELEGRAM_BOT_TOKEN=

# Sentry DSN (optional for local — errors go to console)
NEXT_PUBLIC_SENTRY_DSN=

# Resend API key (optional for local — email won't send)
RESEND_API_KEY=

# PostHog key (optional for local — analytics won't track)
NEXT_PUBLIC_POSTHOG_KEY=
